// This program finds the maximum occurring character in a string entered by the user and displays the result.
#include <iostream>
using namespace std;

int main() {
    char str[200];
    int freq[256] = {0}; // ASCII frequency array

    cout << "Enter a string: ";
    cin.getline(str, 200);

    // Count frequency of each character
    for (int i = 0; str[i] != '\0'; i++) {
        freq[(unsigned char)str[i]]++;
    }

    // Find maximum occurring character
    int maxFreq = 0;
    char maxChar = '\0';
    for (int i = 0; i < 256; i++) {
        if (freq[i] > maxFreq) {
            maxFreq = freq[i];
            maxChar = (char)i;
        }
    }

    if (maxChar != '\0')
        cout << "Maximum occurring character: '" << maxChar 
             << "' (appears " << maxFreq << " times)" << endl;
    else
        cout << "No characters found." << endl;

    return 0;
}
