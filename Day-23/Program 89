// This program finds the first non-repeating character in a string entered by the user and displays the result.
#include <iostream>
using namespace std;

int main() {
    char str[200];
    int freq[256] = {0}; // ASCII frequency array

    cout << "Enter a string: ";
    cin.getline(str, 200);

    // Count frequency of each character
    for (int i = 0; str[i] != '\0'; i++) {
        freq[(unsigned char)str[i]]++;
    }

    // Find first non-repeating character
    char firstNonRepeat = '\0';
    for (int i = 0; str[i] != '\0'; i++) {
        if (freq[(unsigned char)str[i]] == 1) {
            firstNonRepeat = str[i];
            break;
        }
    }

    if (firstNonRepeat != '\0')
        cout << "First non-repeating character: " << firstNonRepeat << endl;
    else
        cout << "No non-repeating character found." << endl;

    return 0;
}
