#include <iostream>
#include <vector>
using namespace std;

int main() {
    int n;
    cout << "Enter number of elements (n-1) for array 1..n: ";
    if (!(cin >> n)) return 0;
    vector<int> arr(n);
    cout << "Enter " << n << " elements: ";
    for (int i = 0; i < n; i++) {
        cin >> arr[i];
    }

    long long sum = 0;
    for (int x : arr) {
        sum += x;
    }

    long long total = (long long)(n + 1) * (n + 2) / 2;
    long long missing = total - sum;

    cout << "Missing number is: " << missing << endl;
    return 0;
}
