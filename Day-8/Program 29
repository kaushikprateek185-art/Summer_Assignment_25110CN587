// C++ program to print a pattern of numbers
#include <iostream>
using namespace std;

int main(){
    int rows;
    cout << "Enter number of rows : ";
    cin>>rows;
    for(int i=1;i<=rows; ++i){
        for(int j=1; j<=i; ++j){
            cout << "8" ;

        }
        cout << "\n";
    }
    return 0;
}