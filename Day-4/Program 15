#include <iostream>
#include <cmath>    // For pow() function
using namespace std;

// Function to check if a number is Armstrong
bool isArmstrong(long long num) {
    if (num < 0) return false; // Armstrong numbers are non-negative

    long long originalNum = num;
    int digits = 0;

    // Count number of digits
    long long temp = num;
    while (temp != 0) {
        temp /= 10;
        digits++;
    }

    // Calculate sum of digits raised to the power of 'digits'
    long long sum = 0;
    temp = num;
    while (temp != 0) {
        int digit = temp % 10;
        sum += static_cast<long long>(pow(digit, digits));
        temp /= 10;
    }

    return sum == originalNum;
}

int main() {
    long long number;

    cout << "Enter a number: ";
    if (!(cin >> number)) { // Input validation
        cout << "Invalid input. Please enter an integer.\n";
        return 1;
    }

    if (isArmstrong(number))
        cout << number << " is an Armstrong number.\n";
    else
        cout << number << " is NOT an Armstrong number.\n";

    return 0;
}
