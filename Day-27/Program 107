// Salary Management System
#include <iostream>
#include <string>
using namespace std;

struct Employee {
    int id;
    string name;
    double basicSalary;
    double hra;   // House Rent Allowance
    double da;    // Dearness Allowance
    double grossSalary;
};

int main() {
    Employee employees[100];
    int count = 0;
    int choice;

    do {
        cout << "\n===== Salary Management System =====" << endl;
        cout << "1. Add Employee Record" << endl;
        cout << "2. Display All Records" << endl;
        cout << "3. Search Employee by ID" << endl;
        cout << "4. Exit" << endl;
        cout << "Enter your choice: ";
        cin >> choice;

        switch (choice) {
            case 1: {
                cout << "\nEnter Employee ID: ";
                cin >> employees[count].id;
                cout << "Enter Name: ";
                cin.ignore();
                getline(cin, employees[count].name);
                cout << "Enter Basic Salary: ";
                cin >> employees[count].basicSalary;

                // Calculate allowances and gross salary
                employees[count].hra = 0.2 * employees[count].basicSalary; // 20% of basic
                employees[count].da  = 0.1 * employees[count].basicSalary; // 10% of basic
                employees[count].grossSalary = employees[count].basicSalary + employees[count].hra + employees[count].da;

                count++;
                cout << "Employee record added successfully!" << endl;
                break;
            }

            case 2: {
                cout << "\n===== All Employee Records =====" << endl;
                for (int i = 0; i < count; i++) {
                    cout << "ID: " << employees[i].id << endl;
                    cout << "Name: " << employees[i].name << endl;
                    cout << "Basic Salary: Rs. " << employees[i].basicSalary << endl;
                    cout << "HRA: Rs. " << employees[i].hra << endl;
                    cout << "DA: Rs. " << employees[i].da << endl;
                    cout << "Gross Salary: Rs. " << employees[i].grossSalary << endl;
                    cout << "-----------------------------" << endl;
                }
                break;
            }

            case 3: {
                int id;
                cout << "\nEnter Employee ID to search: ";
                cin >> id;
                bool found = false;

                for (int i = 0; i < count; i++) {
                    if (employees[i].id == id) {
                        cout << "\nRecord Found!" << endl;
                        cout << "ID: " << employees[i].id << endl;
                        cout << "Name: " << employees[i].name << endl;
                        cout << "Basic Salary: Rs. " << employees[i].basicSalary << endl;
                        cout << "HRA: Rs. " << employees[i].hra << endl;
                        cout << "DA: Rs. " << employees[i].da << endl;
                        cout << "Gross Salary: Rs. " << employees[i].grossSalary << endl;
                        found = true;
                        break;
                    }
                }
                if (!found) {
                    cout << "No employee found with ID " << id << endl;
                }
                break;
            }

            case 4:
                cout << "Exiting program. Goodbye!" << endl;
                break;

            default:
                cout << "Invalid choice. Please try again." << endl;
        }
    } while (choice != 4);

    return 0;
}
