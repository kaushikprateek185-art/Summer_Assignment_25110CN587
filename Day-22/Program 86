// This program counts the number of words in a string entered by the user and displays the result.
#include <iostream>
using namespace std;

int main() {
    char str[200];
    int words = 0;

    cout << "Enter a sentence: ";
    cin.getline(str, 200);

    // Traverse the string
    for (int i = 0; str[i] != '\0'; i++) {
        // Check for spaces (word separator)
        if (str[i] == ' ' && str[i+1] != ' ' && str[i+1] != '\0') {
            words++;
        }
    }

    // Add 1 to count the last word (if sentence is not empty)
    if (str[0] != '\0')
        words++;

    cout << "Number of words = " << words << endl;

    return 0;
}
