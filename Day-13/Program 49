// Program to take input of an array and print it
#include <iostream>
using namespace std;

int main() {
    int arr[5];

    cout << "Enter 5 elements of the array:\n";
    for (int i = 0; i < 5; i++) {
        cout << "Element " << i + 1 << ": ";
        cin >> arr[i];
    }

    cout << "\nArray elements are:\n";
    for (int i = 0; i < 5; i++) {
        cout << arr[i] << " ";
    }

    cout << endl;
    return 0;
}
