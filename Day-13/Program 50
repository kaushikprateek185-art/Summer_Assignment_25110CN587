#include <iostream>
#include <vector>
using namespace std;

int main() {
    int n;
    cout << "Enter number of elements: ";
    if (!(cin >> n) || n <= 0) {
        cout << "Invalid input";
        return 0;
    }

    vector<double> arr(n);
    cout << "Enter " << n << " elements:\n";
    for (int i = 0; i < n; ++i) {
        cin >> arr[i];
    }

    double sum = 0;
    for (int i = 0; i < n; ++i) {
        sum += arr[i];
    }

    double average = sum / n;
    cout << "Sum = " << sum << "\n";
    cout << "Average = " << average << "\n";

    return 0;
}
