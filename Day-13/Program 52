#include <iostream>
using namespace std;

int main() {
    int n;
    cout << "Enter number of elements: ";
    cin >> n;

    int countEven = 0;
    int countOdd = 0;

    cout << "Enter " << n << " integers:\n";
    for (int i = 0; i < n; ++i) {
        int value;
        cin >> value;
        if (value % 2 == 0)
            ++countEven;
        else
            ++countOdd;
    }

    cout << "Even elements: " << countEven << "\n";
    cout << "Odd elements: " << countOdd << "\n";
    return 0;
}
