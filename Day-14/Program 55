// Program to find the second largest element in an array
#include <iostream>
#include <limits>
using namespace std;

int main() {
    int n;
    cin >> n;
    if (n < 2) {
        cout << "Array must have at least two elements";
        return 0;
    }

    int first = numeric_limits<int>::min();
    int second = numeric_limits<int>::min();
    for (int i = 0; i < n; ++i) {
        int x;
        cin >> x;
        if (x > first) {
            second = first;
            first = x;
        } else if (x > second && x < first) {
            second = x;
        }
    }

    if (second == numeric_limits<int>::min()) {
        cout << "No second largest element";
    } else {
        cout << second;
    }

    return 0;
}
