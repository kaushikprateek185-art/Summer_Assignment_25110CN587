// Quiz Application
#include <iostream>
using namespace std;

int main() {
    int score = 0;
    int answer;

    cout << "===== Quiz Application =====" << endl;

    // Question 1
    cout << "\nQ1. What is the capital of India?" << endl;
    cout << "1. Mumbai" << endl;
    cout << "2. Delhi" << endl;
    cout << "3. Kolkata" << endl;
    cout << "4. Chennai" << endl;
    cout << "Enter your choice (1-4): ";
    cin >> answer;
    if (answer == 2) {
        cout << "Correct!" << endl;
        score++;
    } else {
        cout << "Wrong! The correct answer is Delhi." << endl;
    }

    // Question 2
    cout << "\nQ2. Who is known as the father of C++?" << endl;
    cout << "1. James Gosling" << endl;
    cout << "2. Bjarne Stroustrup" << endl;
    cout << "3. Dennis Ritchie" << endl;
    cout << "4. Guido van Rossum" << endl;
    cout << "Enter your choice (1-4): ";
    cin >> answer;
    if (answer == 2) {
        cout << "Correct!" << endl;
        score++;
    } else {
        cout << "Wrong! The correct answer is Bjarne Stroustrup." << endl;
    }

    // Question 3
    cout << "\nQ3. Which planet is known as the Red Planet?" << endl;
    cout << "1. Earth" << endl;
    cout << "2. Mars" << endl;
    cout << "3. Jupiter" << endl;
    cout << "4. Venus" << endl;
    cout << "Enter your choice (1-4): ";
    cin >> answer;
    if (answer == 2) {
        cout << "Correct!" << endl;
        score++;
    } else {
        cout << "Wrong! The correct answer is Mars." << endl;
    }

    // Final Score
    cout << "\n===== Quiz Finished =====" << endl;
    cout << "Your total score is: " << score << " out of 3" << endl;

    if (score == 3) {
        cout << "Excellent! 🎉" << endl;
    } else if (score == 2) {
        cout << "Good job! 👍" << endl;
    } else {
        cout << "Better luck next time! 🙂" << endl;
    }

    return 0;
}
