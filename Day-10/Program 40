#include <iostream>
using namespace std;
int main (){
    int rows=5 ;
    for (int i=0; i< rows; i++){
        for (int j=0; j<rows -i-1 ; j++){
            cout << " ";
        }
        char ch = 'A';
        for (int j=0 ; j<=i; j++){
            cout << ch++;
        }
        ch-=2;
        for (int j=0; j<i; j++){
            cout << ch--;
        }
        cout << endl;
    }
    return 0;
}