// This program calculates the length of a string entered by the user and displays the result.
#include <iostream>
using namespace std;

int main() {
    char str[100];
    int length = 0;

    cout << "Enter a string: ";
    cin.getline(str, 100);

    // Count characters until null terminator '\0'
    while (str[length] != '\0') {
        length++;
    }

    cout << "Length of the string = " << length << endl;

    return 0;
}
