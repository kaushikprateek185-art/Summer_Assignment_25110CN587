#include <iostream>
#include <vector>
using namespace std;

int main() {
    int n;
    if (!(cin >> n)) return 0;
    vector<int> a(n);
    for (int i = 0; i < n; ++i) {
        cin >> a[i];
    }
    int idx = 0;
    for (int i = 0; i < n; ++i) {
        if (a[i] != 0) {
            a[idx++] = a[i];
        }
    }
    while (idx < n) {
        a[idx++] = 0;
    }
    for (int i = 0; i < n; ++i) {
        cout << a[i];
        if (i + 1 < n) cout << " ";
    }
    return 0;
}
