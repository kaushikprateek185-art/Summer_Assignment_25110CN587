// Program to rotate an array by d positions
#include <iostream>
#include <vector>
using namespace std;

int main() {
    int n, d;
    cin >> n >> d;
    vector<int> a(n);
    for (int i = 0; i < n; i++) {
        cin >> a[i];
    }
    if (n > 0) {
        d = d % n;
        if (d < 0) d += n;
        for (int i = 0; i < n; i++) {
            cout << a[(i + d) % n];
            if (i < n - 1) cout << " ";
        }
    }
    return 0;
}
