#include <iostream>
#include <cstdlib> // for abs()

// Function to compute GCD using Euclidean algorithm
int gcd(int a, int b) {
    // Ensure both numbers are non-negative
    a = std::abs(a);
    b = std::abs(b);

    // Euclidean algorithm
    while (b != 0) {
        int temp = b;
        b = a % b;
        a = temp;
    }
    return a; // GCD is always non-negative
}

int main() {
    int num1, num2;

    std::cout << "Enter two integers: ";

    // Input validation
    if (!(std::cin >> num1 >> num2)) {
        std::cerr << "Invalid input. Please enter integers only.\n";
        return 1;
    }

    // Special case: both numbers are zero
    if (num1 == 0 && num2 == 0) {
        std::cout << "GCD is undefined for both numbers being zero.\n";
        return 0;
    }

    int result = gcd(num1, num2);
    std::cout << "GCD of " << num1 << " and " << num2 << " is: " << result << "\n";

    return 0;
}
