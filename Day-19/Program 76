// This program calculates the sum of the primary and secondary diagonals of a square matrix and displays the results.
#include <iostream>
using namespace std;

int main() {
    int n;
    cout << "Enter size of square matrix (n x n): ";
    cin >> n;

    int mat[n][n];

    // Input matrix
    cout << "Enter elements of the matrix:\n";
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            cin >> mat[i][j];
        }
    }

    int primarySum = 0, secondarySum = 0;

    // Calculate sums of diagonals
    for (int i = 0; i < n; i++) {
        primarySum += mat[i][i];           // Primary diagonal (top-left to bottom-right)
        secondarySum += mat[i][n - i - 1]; // Secondary diagonal (top-right to bottom-left)
    }

    cout << "Sum of primary diagonal = " << primarySum << endl;
    cout << "Sum of secondary diagonal = " << secondarySum << endl;
    cout << "Total sum of both diagonals = " << primarySum + secondarySum << endl;

    return 0;
}
