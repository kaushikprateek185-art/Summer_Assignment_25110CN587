// This program removes duplicate characters from a string entered by the user and displays the result.
#include <iostream>
using namespace std;

int main() {
    char str[200];
    bool seen[256] = {false}; // ASCII tracker

    cout << "Enter a string: ";
    cin.getline(str, 200);

    int j = 0; // index for new string

    // Traverse and keep only first occurrence of each character
    for (int i = 0; str[i] != '\0'; i++) {
        unsigned char ch = str[i];
        if (!seen[ch]) {
            seen[ch] = true;
            str[j++] = ch;
        }
    }

    str[j] = '\0'; // terminate new string

    cout << "String after removing duplicates: " << str << endl;

    return 0;
}
