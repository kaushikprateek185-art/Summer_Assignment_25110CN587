// This program finds the common elements between two arrays and displays them.
#include <iostream>
using namespace std;

int main() {
    int n1, n2;

    // Input sizes of two arrays
    cout << "Enter size of first array: ";
    cin >> n1;
    cout << "Enter size of second array: ";
    cin >> n2;

    int arr1[n1], arr2[n2];

    // Input elements of first array
    cout << "Enter elements of first array:\n";
    for (int i = 0; i < n1; i++) {
        cin >> arr1[i];
    }

    // Input elements of second array
    cout << "Enter elements of second array:\n";
    for (int i = 0; i < n2; i++) {
        cin >> arr2[i];
    }

    cout << "Common elements:\n";
    for (int i = 0; i < n1; i++) {
        for (int j = 0; j < n2; j++) {
            if (arr1[i] == arr2[j]) {
                cout << arr1[i] << " ";
                break; // avoid printing duplicates if arr2 has repeats
            }
        }
    }

    return 0;
}
